# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/moneylog?retryWrites=true&w=majority

# NextAuth.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars

# Field encryption (mongoose-field-encryption) — 32-byte hex or base64 key
FIELD_ENCRYPTION_KEY=your-32-byte-encryption-key-here

# SMTP (monthly report email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=MoneyLog <your-email@gmail.com>

# Cron endpoint protection (Cloudtype + external scheduler)
CRON_SECRET=your-random-cron-secret-min-32-chars
