# MoneyLog — Cloudtype 배포용 환경 변수 템플릿
#
# 사용 방법
# 1. 이 파일을 복사해 값을 채웁니다 (커밋하지 마세요).
# 2. Cloudtype 대시보드 → 서비스 → 배포 설정 → Environment Variables
# 3. 아래 내용을 Drag & Drop 하거나 항목별로 붙여넣습니다.
#
# 배포 URL 확정 후 NEXTAUTH_URL을 실제 주소로 맞추고 재배포하세요.
# FIELD_ENCRYPTION_KEY는 배포 후 절대 변경하지 마세요.

# --- 필수 ---

MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/moneylog?retryWrites=true&w=majority

# Cloudtype 프리뷰/커스텀 도메인 (끝에 / 없음)
NEXTAUTH_URL=https://your-service.cloudtype.app

# Cloudtype 등 리버스 프록시 뒤에서 NextAuth 동작용
AUTH_TRUST_HOST=true

NEXTAUTH_SECRET=replace-with-random-secret-min-32-chars

# 32바이트 hex(64자) 또는 base64 — 생성 후 변경 금지
FIELD_ENCRYPTION_KEY=replace-with-64-char-hex-or-base64-key

# 서버 타임존 (월간 이메일·당월 집계)
TZ=Asia/Seoul

# Cloudtype이 주입하는 포트 (보통 3000) — start 스크립트가 자동 사용
PORT=3000

# --- 선택: 월간 이메일 리포트 ---

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
EMAIL_FROM=MoneyLog <your-email@gmail.com>

# 외부 cron이 /api/cron/monthly-email 호출 시 Authorization Bearer 값
CRON_SECRET=replace-with-random-cron-secret-min-32-chars
